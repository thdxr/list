{
  "name": "@opentunnel/server",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anomalyco/opentunnel.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev:watch": "vp pack --watch",
    "dev:run": "node ./dist/index.mjs",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build"
  },
  "dependencies": {
    "@effect/opentelemetry": "catalog:",
    "@effect/platform-node": "catalog:",
    "@opentelemetry/auto-instrumentations-node": "catalog:",
    "@opentelemetry/exporter-trace-otlp-http": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-node": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/sdk-trace-node": "catalog:",
    "@opentelemetry/semantic-conventions": "catalog:",
    "@opentunnel/core": "workspace:*",
    "@peculiar/x509": "catalog:",
    "effect": "catalog:",
    "reflect-metadata": "catalog:",
    "ws": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/ws": "catalog:",
    "@typescript/native-preview": "catalog:",
    "bumpp": "catalog:",
    "typescript": "catalog:",
    "vite-plus": "catalog:"
  },
  "inlinedDependencies": {
    "@peculiar/acme-client": "1.8.2",
    "@peculiar/acme-core": "1.8.2",
    "@peculiar/jose": "1.8.2",
    "env-paths": "4.0.0",
    "is-safe-filename": "0.1.1",
    "pvtsutils": "1.3.6",
    "read-tls-client-hello": "2.0.0",
    "tslib": [
      "1.14.1",
      "2.8.1"
    ],
    "tsyringe": "4.10.0"
  }
}
